datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id              Int     @id @default(autoincrement())
  name            String
  category        String
  price           Float
  originalPrice   Float?
  img             String
  rating          Float
  reviews         Int
  description     String
  longDescription String
  badge           String?
  details         Json
}
